{
  "manifest_version": 3,
  "name": "Webflow Cleanup Assistant",
  "version": "1.0.0",
  "description": "Audit published Webflow pages and get a DOM cleanup report in the popup.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Webflow Cleanup Assistant",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab", "scripting"]
}
